# Mẫu env cho docker compose. Copy thành `.env` rồi chỉnh giá trị:
#   cp .env.example .env
# Compose tự động đọc `.env` khi chạy `docker compose up -d`.

# Port host cho frontend.
# LƯU Ý (Windows): tránh dải port 3922-4221 vì Hyper-V/WSL thường reserve sẵn,
# gây lỗi "bind: an attempt was made to access a socket in a way forbidden".
# Kiểm tra dải bị cấm bằng: netsh interface ipv4 show excludedportrange protocol=tcp
FRONTEND_HOST_PORT=4300

# Phải khớp với FRONTEND_HOST_PORT ở trên.
# NextAuth dùng giá trị này để redirect sau khi đăng nhập — sai port sẽ "từ chối kết nối".
NEXTAUTH_URL=http://localhost:4300
APP_BASE_URL=http://localhost:4300

# BẮT BUỘC đổi ở môi trường thật. Sinh chuỗi ngẫu nhiên, ví dụ: openssl rand -base64 32
NEXTAUTH_SECRET=dev-only-change-me

# console = in link email ra log container (tiện cho dev).
# Đổi sang smtp + điền SMTP_* nếu muốn gửi email thật.
EMAIL_PROVIDER=console
# EMAIL_FROM="SportLife <no-reply@sportlife.local>"
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_APP_PASSWORD=

# Tài khoản admin được seed lần đầu.
ADMIN_SEED_EMAIL=admin@sportlife.local
ADMIN_SEED_PASSWORD=ChangeMe123!

# Cấu hình dịch vụ SMS (console / esms / speedsms)
SMS_PROVIDER=console
ESMS_API_KEY=
ESMS_SECRET_KEY=
ESMS_BRANDNAME=
SPEEDSMS_ACCESS_TOKEN=
SPEEDSMS_SENDER=

