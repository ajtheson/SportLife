generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLAYER
  VENUE_OWNER
  ADMIN
}

enum UserStatus {
  ACTIVE
  LOCKED
  DELETED
}

enum ConfigStatus {
  ACTIVE
  INACTIVE
}

enum ApprovalStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum VisibilityStatus {
  ACTIVE
  HIDDEN
  LOCKED
  DELETED
}

enum MatchStatus {
  OPEN
  FULL
  CLOSED
  CANCELED
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum ContentStatus {
  PENDING
  VISIBLE
  HIDDEN
  DELETED
}

enum CommunityPostType {
  DISCUSSION
  ADVICE
  EVENT
  GENERAL
}

enum NotificationType {
  MATCH_JOIN_REQUESTED
  MATCH_JOIN_APPROVED
  MATCH_JOIN_REJECTED
  MATCH_UPDATED
  CHAT_MESSAGE
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  role          UserRole
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts             Account[]
  sessions             Session[]
  playerProfile        PlayerProfile?
  venueOwnerProfile    VenueOwnerProfile?
  ownedVenues          Venue[]
  matches              Match[]
  joinRequests         MatchJoinRequest[]
  communityPosts       CommunityPost[]
  comments             Comment[]
  notifications        Notification[]       @relation("NotificationRecipient")
  conversationsAsA     Conversation[]       @relation("ConversationUserA")
  conversationsAsB     Conversation[]       @relation("ConversationUserB")
  chatMessages         ChatMessage[]
  verificationTokens   VerificationToken[]
  passwordResetTokens  PasswordResetToken[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PlayerProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  displayName  String
  phone        String   @unique
  avatarUrl    String?
  areaId       String?
  introduction String?
  availability String?
  contactInfo  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  area        Area?              @relation(fields: [areaId], references: [id])
  sportLevels PlayerSportLevel[]
}

model PlayerSportLevel {
  id              String @id @default(cuid())
  playerProfileId String
  sportId         String
  skillLevelId    String

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  sport         Sport         @relation(fields: [sportId], references: [id])
  skillLevel    SkillLevel    @relation(fields: [skillLevelId], references: [id])

  @@unique([playerProfileId, sportId])
}

model VenueOwnerProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  businessName String
  phone        String   @unique
  contactInfo  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Sport {
  id        String       @id @default(cuid())
  name      String       @unique
  status    ConfigStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  skillLevels       SkillLevel[]
  playerSportLevels PlayerSportLevel[]
  venueSports       VenueSport[]
  matches           Match[]
  communityPosts    CommunityPost[]
}

model SkillLevel {
  id        String       @id @default(cuid())
  sportId   String
  name      String
  order     Int
  status    ConfigStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  sport             Sport              @relation(fields: [sportId], references: [id], onDelete: Cascade)
  playerSportLevels PlayerSportLevel[]
  matchExpectedLevels MatchExpectedLevel[]
  matches           Match[]

  @@unique([sportId, name])
  @@index([sportId, order])
}

model Area {
  id        String       @id @default(cuid())
  name      String
  type      String
  city      String       @default("Hanoi")
  status    ConfigStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  playerProfiles PlayerProfile[]
  venues         Venue[]
  matches        Match[]
  communityPosts CommunityPost[]

  @@unique([city, name, type])
  @@index([city, name])
}

model Venue {
  id               String           @id @default(cuid())
  ownerId          String
  name             String
  address          String
  areaId           String
  phone            String
  description      String?
  availabilityNote String?
  openingHours     Json?
  referencePrice   String?
  contactInfo      Json?
  approvalStatus   ApprovalStatus   @default(PENDING_APPROVAL)
  visibilityStatus VisibilityStatus @default(ACTIVE)
  rejectionReason  String?
  viewCount        Int              @default(0)
  contactCount     Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  owner  User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  area   Area         @relation(fields: [areaId], references: [id])
  sports VenueSport[]
  images VenueImage[]
  chatConversations Conversation[] @relation("ConversationVenueContext")

  @@index([areaId, approvalStatus, visibilityStatus])
}

model VenueSport {
  id      String @id @default(cuid())
  venueId String
  sportId String

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  sport Sport @relation(fields: [sportId], references: [id])

  @@unique([venueId, sportId])
}

model VenueImage {
  id        String   @id @default(cuid())
  venueId   String
  url       String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
}

model Match {
  id              String      @id @default(cuid())
  ownerId         String
  sportId         String
  areaId          String
  time            DateTime
  detailedAddress String?
  requiredPlayers Int
  expectedLevelId String?
  status          MatchStatus @default(OPEN)
  description     String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  owner         User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sport         Sport              @relation(fields: [sportId], references: [id])
  area          Area               @relation(fields: [areaId], references: [id])
  expectedLevel SkillLevel?        @relation(fields: [expectedLevelId], references: [id])
  expectedLevels MatchExpectedLevel[]
  joinRequests  MatchJoinRequest[]
  chatConversations Conversation[] @relation("ConversationMatchContext")

  @@index([sportId, areaId, time, status])
}

model MatchExpectedLevel {
  id           String @id @default(cuid())
  matchId      String
  skillLevelId String

  match      Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  skillLevel SkillLevel @relation(fields: [skillLevelId], references: [id])

  @@unique([matchId, skillLevelId])
}

model MatchJoinRequest {
  id          String            @id @default(cuid())
  matchId     String
  requesterId String
  status      JoinRequestStatus @default(PENDING)
  message     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  match     Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  requester User  @relation(fields: [requesterId], references: [id], onDelete: Cascade)

  @@unique([matchId, requesterId])
}

model CommunityPost {
  id        String            @id @default(cuid())
  authorId  String
  sportId   String
  postType  CommunityPostType
  areaId    String?
  title     String            @default("Untitled")
  content   String
  status    ContentStatus     @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  sport    Sport     @relation(fields: [sportId], references: [id])
  area     Area?     @relation(fields: [areaId], references: [id])
  comments Comment[]

  @@index([sportId, postType, areaId, status])
}

model Comment {
  id        String        @id @default(cuid())
  postId    String
  authorId  String
  content   String
  status    ContentStatus @default(VISIBLE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  post   CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  type        NotificationType
  referenceId String
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  recipient User @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, readAt, createdAt])
}

model Conversation {
  id              String   @id @default(cuid())
  userAId         String
  userBId         String
  venueContextId  String?
  matchContextId  String?
  lastMessageAt   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userA        User          @relation("ConversationUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB        User          @relation("ConversationUserB", fields: [userBId], references: [id], onDelete: Cascade)
  venueContext Venue?        @relation("ConversationVenueContext", fields: [venueContextId], references: [id], onDelete: SetNull)
  matchContext Match?        @relation("ConversationMatchContext", fields: [matchContextId], references: [id], onDelete: SetNull)
  messages     ChatMessage[]

  @@unique([userAId, userBId])
  @@index([userAId, lastMessageAt])
  @@index([userBId, lastMessageAt])
  @@index([venueContextId])
  @@index([matchContextId])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  readAt         DateTime?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
}
